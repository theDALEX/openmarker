{
  "name": "openmarker",
  "version": "1.0.0",
  "description": "openmarker is an AI-powered grading assistant for teachers and lecturers. Automatically grade essays and reports so you can spend more time teaching and engaging with students.",
  "license": "MIT",
  "author": "Dalex Davis",
  "type": "commonjs",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start-nodemon": "nodemon --exec electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.dalexdavis.openmarker",
    "productName": "OpenMarker",
    "publish": "never",
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/openmarkerIcon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/openmarkerIcon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/openmarkerIcon.png",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "mammoth": "^1.12.0",
    "node-llama-cpp": "^3.18.1"
  }
}